{
    "latex-workshop.latex.tools": [
        {
            "name": "xelatex",
            "command": "xelatex",
            "args": [
                "-synctex=1",
                "-interaction=nonstopmode",
                "-file-line-error",
                "%DOC%"
            ]
        },
        {
            "name": "bibtex",
            "command": "bibtex",
            "args": [
                "%DOCFILE%"
            ]
        },
        {
            "name": "linux-clean-script",
            "command": "bash",
            "args": [
                "./scripts/linux-clean.sh"
            ]
        },
        {
            "name": "macos-clean-script",
            "command": "bash",
            "args": [
                "./scripts/macos-clean.sh"
            ]
        }
    ],
    "latex-workshop.latex.recipes": [
        {
            "name": "Full build (xelatex+bibtex)",
            "tools": [
                "xelatex",
                "bibtex",
                "xelatex",
                "xelatex"
            ]
        },
        {
            "name": "Quick build (xelatex only)",
            "tools": [
                "xelatex"
            ]
        }
    ],
    "latex-workshop.latex.recipe.default": "Full build (xelatex+bibtex)",
    "latex-workshop.view.pdf.viewer": "tab",
    "python.defaultInterpreterPath": "C:/Users/23720/miniconda3/python.exe",
    "python-envs.pythonProjects": [
        {
            "path": ".",
            "envManager": "ms-python.python:conda",
            "packageManager": "ms-python.python:conda"
        }
    ]
}