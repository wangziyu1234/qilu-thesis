idRDefault="00003AE7"><ns0:pPr><ns0:spacing ns0:line="360" ns0:lineRule="auto" /><ns0:jc ns0:val="left" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>主题：差速驱动底盘运动学建模、路径规划与</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>MATLAB</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>仿真</ns0:t></ns0:r></ns0:p><ns0:p ns2:paraId="3F7ACD16" ns2:textId="1DEFD17C" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:spacing ns0:line="360" ns0:lineRule="auto" /><ns0:jc ns0:val="left" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>指导内容：在老师的指导下，建立了双轮差速驱动底盘的运动学模型，推导了线速度、角速度与位姿变化的运动学方程。在</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>MATLAB</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>环境下编写了仿真程序，采用前向欧拉积分方法，对直线轨迹、定曲率圆弧轨迹、</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>S</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>形轨迹和</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>8</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>字形轨迹四种典型运动工况进行了仿真分析，验证了差速底盘在不同速度指令组合下的轨迹演化规律和姿态调整能力。在此基础上，进一步实现了Hybrid A*全局路径规划算法，在包含货架障碍物的仓储地图上完成了无碰撞路径搜索；并设计了5路TCRT5000红外传感器PID循迹模型，验证了路径规划与循迹跟踪的可行性。</ns0:t></ns0:r></ns0:p><ns0:p ns2:paraId="3F7ACD17" ns2:textId="77777777" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:spacing ns0:line="360" ns0:lineRule="auto" /><ns0:jc ns0:val="left" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>指导教师意见：</ns0:t></ns0:r></ns0:p></ns0:tc></ns0:tr><ns0:tr ns0:rsidR="00134469" ns2:paraId="3F7ACD1D" ns2:textId="77777777"><ns0:trPr><ns0:trHeight ns0:val="1564" /></ns0:trPr><ns0:tc><ns0:tcPr><ns0:tcW ns0:w="1621" ns0:type="dxa" /><ns0:vAlign ns0:val="center" /></ns0:tcPr><ns0:p ns2:paraId="3F7ACD19" ns2:textId="77777777" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:jc ns0:val="center" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>第七次指导</ns0:t></ns0:r></ns0:p></ns0:tc><ns0:tc><ns0:tcPr><ns0:tcW ns0:w="7887" ns0:type="dxa" /><ns0:gridSpan ns0:val="5" /><ns0:vAlign ns0:val="center" /></ns0:tcPr><ns0:p ns2:paraId="3F7ACD1A" ns2:textId="77777777" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:spacing ns0:line="360" ns0:lineRule="auto" /><ns0:jc ns0:val="left" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>主题：双轮差速</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>PID</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>控制器设计与</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>MATLAB</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>仿真验证</ns0:t></ns0:r></ns0:p><ns0:p ns2:paraId="3F7ACD1B" ns2:textId="77777777" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:spacing ns0:line="360" ns0:lineRule="auto" /><ns0:jc ns0:val="left" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>指导内容：在老师的指导下，设计了基于</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>PID</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>控制算法的双环级联运动控制器。外环为位姿环，依据位置偏差和航向偏差计算期望线速度与角速度；内环为轮速环，由左右两个独立的</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>PI</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>控制器构成，负责跟踪轮速指令并输出电机控制电压。在</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t /></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>MATLAB</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>环境下搭建了差速小车闭环仿真模型，</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>完成了阶跃响应、定点镇定、直线跟踪和圆形轨迹跟踪四类典型工况的仿真验证。结果表明，控制器在四种工况下均具有良好的跟踪性能，满足仓储小车的基本运动控制需求。</ns0:t></ns0:r></ns0:p><ns0:p ns2:paraId="3F7ACD1C" ns2:textId="77777777" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:spacing ns0:line="360" ns0:lineRule="auto" /><ns0:jc ns0:val="left" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>指导教师意见：</ns0:t></ns0:r></ns0:p></ns0:tc></ns0:tr><ns0:tr ns0:rsidR="00134469" ns2:paraId="3F7ACD22" ns2:textId="77777777"><ns0:trPr><ns0:trHeight ns0:val="1564" /></ns0:trPr><ns0:tc><ns0:tcPr><ns0:tcW ns0:w="1621" ns0:type="dxa" /><ns0:vAlign ns0:val="center" /></ns0:tcPr><ns0:p ns2:paraId="3F7ACD1E" ns2:textId="77777777" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:jc ns0:val="center" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>第八次指导</ns0:t></ns0:r></ns0:p></ns0:tc><ns0:tc><ns0:tcPr><ns0:tcW ns0:w="7887" ns0:type="dxa" /><ns0:gridSpan ns0:val="5" /><ns0:vAlign ns0:val="center" /></ns0:tcPr><ns0:p ns2:paraId="3F7ACD1F" ns2:textId="77777777" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:spacing ns0:line="360" ns0:lineRule="auto" /><ns0:jc ns0:val="left" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>主题：论文撰写、修改与答辩准备</ns0:t></ns0:r></ns0:p><ns0:p ns2:paraId="3F7ACD20" ns2:textId="77777777" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:spacing ns0:line="360" ns0:lineRule="auto" /><ns0:jc ns0:val="left" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>指导内容：在老师的指导下，完成了毕业论文的撰写工作，全文共七章，包括引言、总体方案设计、机械结构设计、电气系统设计、运动学建模与仿真、运动控制算法分析和结论。对论文进行了多次修改与完善，规范了图表格式、参考文献引用和</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>LaTeX</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>排版。同时准备了答辩</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>PPT</ns0:t></ns0:r><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>，梳理了研究工作的整体思路和创新点，为毕业答辩做好了充分准备。</ns0:t></ns0:r></ns0:p><ns0:p ns2:paraId="3F7ACD21" ns2:textId="77777777" ns0:rsidR="00134469" ns0:rsidRDefault="00003AE7"><ns0:pPr><ns0:spacing ns0:line="360" ns0:lineRule="auto" /><ns0:jc ns0:val="left" /><ns0:rPr><ns0:sz ns0:val="24" /></ns0:rPr></ns0:pPr><ns0:r><ns0:rPr><ns0:rFonts ns0:hint="eastAsia" /><ns0:sz ns0:val="24" /></ns0:rPr><ns0:t>指导教师意见：</ns0:t></ns0:r></ns0:p></ns0:tc></ns0:tr><ns0:tr ns0:rsidR="00134469" ns2:paraId="3F7ACD25" ns2:textId="77777777"><ns0:trPr><ns0:trHeight ns0:val="1564" /></ns0:trPr><ns0:tc><ns0:tcPr><ns0:tcW ns0:w="1621" ns0:type="dxa" /><ns0:vAlign ns0:val="center" /></ns0:tcPr><ns0:p ns2:paraId="3F7ACD23" ns2:textId="77777777" ns0:rsidR="00134469